# Copy this file and fill in real values in Railway Dashboard → Variables

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ── Database (MongoDB Atlas recommended) ──────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Redis (Railway Redis plugin — auto-injected as REDIS_URL) ─────────────────
REDIS_URL=redis://...

# ── JWT (generate with: node -e "require('crypto').randomBytes(64).toString('base64url')|console.log") ──
ACCESS_TOKEN_SECRET=<strong_random_secret>
REFRESH_TOKEN_SECRET=<strong_random_secret>
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ── Frontend (Vercel URL) ─────────────────────────────────────────────────────
FRONTEND_URL=https://callingagent.buildbysandeep.dev

# ── Bolna API ─────────────────────────────────────────────────────────────────
BOLNA_API_BASE=https://api.bolna.ai

# ── Google OAuth (Google Cloud Console) ──────────────────────────────────────
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# ── Mailer (Gmail App Password recommended) ───────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=you@gmail.com
MAIL_PASS=<gmail_app_password>
MAIL_FROM=Bolna AI <you@gmail.com>
MAIL_TO=you@gmail.com
